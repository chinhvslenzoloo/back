generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id                   String                @id @db.Char(36)
  name                 String                @db.VarChar(120)
  createdAt            DateTime              @default(now()) @map("created_at")
  users                User[]
  companies            Company[]
  contacts             Contact[]
  deals                Deal[]
  activities           Activity[]
  reminders            Reminder[]
  auditLogs            AuditLog[]
  csvImportJobs        CsvImportJob[]
  conversations        Conversation[]
  conversationMessages ConversationMessage[]
  dealComments         DealComment[]
  products             Product[]
  orders               Order[]

  @@map("tenants")
}

model User {
  id                   String                @id @db.Char(36)
  tenantId             String                @map("tenant_id") @db.Char(36)
  fullName             String                @map("full_name") @db.VarChar(120)
  email                String                @unique @db.VarChar(180)
  passwordHash         String                @map("password_hash") @db.VarChar(255)
  googleSub            String?               @unique @map("google_sub") @db.VarChar(64)
  role                 Role                  @default(user)
  createdAt            DateTime              @default(now()) @map("created_at")
  updatedAt            DateTime              @updatedAt @map("updated_at")
  deletedAt            DateTime?             @map("deleted_at")
  tenant               Tenant                @relation(fields: [tenantId], references: [id])
  contacts             Contact[]             @relation("ContactCreator")
  companies            Company[]             @relation("CompanyCreator")
  deals                Deal[]                @relation("DealCreator")
  activities           Activity[]            @relation("ActivityCreator")
  reminders            Reminder[]
  auditLogs            AuditLog[]            @relation("AuditActor")
  csvImportJobs        CsvImportJob[]        @relation("CsvImportCreator")
  conversationsAsA     Conversation[]        @relation("ConversationUserA")
  conversationsAsB     Conversation[]        @relation("ConversationUserB")
  assignedConversations Conversation[]       @relation("ConversationAssignee")
  conversationMessages ConversationMessage[]
  dealComments         DealComment[]
  passwordResetTokens  PasswordResetToken[]
  orders               Order[]
  products             Product[]             @relation("ProductCreator")

  @@index([tenantId, role], map: "idx_users_tenant_role")
  @@map("users")
}

model PasswordResetToken {
  id        String    @id @db.Char(36)
  userId    String    @map("user_id") @db.Char(36)
  tokenHash String    @map("token_hash") @db.VarChar(64)
  createdAt DateTime  @default(now()) @map("created_at")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId, expiresAt], map: "idx_pwd_reset_user_exp")
  @@index([tokenHash], map: "idx_pwd_reset_token_hash")
  @@map("password_reset_tokens")
}

model Company {
  id          String    @id @db.Char(36)
  tenantId    String    @map("tenant_id") @db.Char(36)
  name        String    @db.VarChar(180)
  industry    String?   @db.VarChar(120)
  website     String?   @db.VarChar(180)
  description String?   @db.Text
  logo        String?   @db.VarChar(255)
  isVendor    Boolean   @default(false) @map("is_vendor")
  createdBy   String    @map("created_by") @db.Char(36)
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")
  tenant      Tenant    @relation(fields: [tenantId], references: [id])
  creator     User      @relation("CompanyCreator", fields: [createdBy], references: [id])
  contacts    Contact[]
  products    Product[]

  @@index([tenantId], map: "idx_companies_tenant")
  @@map("companies")
}

model Contact {
  id         String        @id @db.Char(36)
  tenantId   String        @map("tenant_id") @db.Char(36)
  companyId  String?       @map("company_id") @db.Char(36)
  name       String        @db.VarChar(160)
  phone      String?       @db.VarChar(32)
  email      String?       @db.VarChar(180)
  status     ContactStatus @default(lead)
  createdBy  String        @map("created_by") @db.Char(36)
  createdAt  DateTime      @default(now()) @map("created_at")
  updatedAt  DateTime      @updatedAt @map("updated_at")
  deletedAt  DateTime?     @map("deleted_at")
  tenant     Tenant        @relation(fields: [tenantId], references: [id])
  company    Company?      @relation(fields: [companyId], references: [id])
  creator    User          @relation("ContactCreator", fields: [createdBy], references: [id])
  deals         Deal[]
  activities    Activity[]
  conversations Conversation[] @relation("ConversationContact")

  @@index([tenantId, status], map: "idx_contacts_tenant_status")
  @@map("contacts")
}

model Deal {
  id            String         @id @db.Char(36)
  tenantId      String         @map("tenant_id") @db.Char(36)
  contactId     String?        @map("contact_id") @db.Char(36)
  title         String         @db.VarChar(220)
  amount        Decimal        @default(0) @db.Decimal(14, 2)
  stage         DealStage      @default(prospect)
  deadline      DateTime?
  createdBy     String         @map("created_by") @db.Char(36)
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  deletedAt     DateTime?      @map("deleted_at")
  tenant        Tenant         @relation(fields: [tenantId], references: [id])
  contact       Contact?       @relation(fields: [contactId], references: [id])
  creator       User           @relation("DealCreator", fields: [createdBy], references: [id])
  dealComments  DealComment[]
  productId     String?        @map("product_id") @db.Char(36)
  product       Product?       @relation(fields: [productId], references: [id])
  conversations Conversation[]
  order         Order?

  @@index([tenantId, stage, deadline], map: "idx_deals_tenant_stage_deadline")
  @@index([productId], map: "idx_deals_product_id")
  @@map("deals")
}

model Activity {
  id              String       @id @db.Char(36)
  tenantId        String       @map("tenant_id") @db.Char(36)
  contactId       String       @map("contact_id") @db.Char(36)
  type            ActivityType
  note            String       @db.Text
  durationMinutes Int?         @map("duration_minutes")
  outcome         String?      @map("outcome") @db.VarChar(220)
  happenedAt      DateTime     @map("happened_at")
  createdBy       String       @map("created_by") @db.Char(36)
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")
  deletedAt       DateTime?    @map("deleted_at")
  tenant          Tenant       @relation(fields: [tenantId], references: [id])
  contact         Contact      @relation(fields: [contactId], references: [id])
  creator         User         @relation("ActivityCreator", fields: [createdBy], references: [id])

  @@index([tenantId, contactId], map: "idx_activities_tenant_contact")
  @@map("activities")
}

model Reminder {
  id         String         @id @db.Char(36)
  tenantId   String         @map("tenant_id") @db.Char(36)
  userId     String         @map("user_id") @db.Char(36)
  entityType ReminderEntity @map("entity_type")
  entityId   String         @map("entity_id") @db.Char(36)
  subject    String         @db.VarChar(220)
  remindAt   DateTime       @map("remind_at")
  status     ReminderStatus @default(pending)
  sentAt     DateTime?      @map("sent_at")
  createdAt  DateTime       @default(now()) @map("created_at")
  updatedAt  DateTime       @updatedAt @map("updated_at")
  tenant     Tenant         @relation(fields: [tenantId], references: [id])
  user       User           @relation(fields: [userId], references: [id])

  @@index([tenantId, status, remindAt], map: "idx_reminders_tenant_status_time")
  @@map("reminders")
}

model AuditLog {
  id          Int      @id @default(autoincrement())
  tenantId    String   @map("tenant_id") @db.Char(36)
  actorUserId String   @map("actor_user_id") @db.Char(36)
  action      String   @db.VarChar(120)
  entityType  String   @map("entity_type") @db.VarChar(60)
  entityId    String   @map("entity_id") @db.Char(36)
  beforeJson  Json?    @map("before_json")
  afterJson   Json?    @map("after_json")
  createdAt   DateTime @default(now()) @map("created_at")
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  actor       User     @relation("AuditActor", fields: [actorUserId], references: [id])

  @@index([tenantId, entityType, entityId], map: "idx_audit_tenant_entity")
  @@map("audit_logs")
}

model Conversation {
  id         String    @id @db.Char(36)
  tenantId   String    @map("tenant_id") @db.Char(36)
  userAId    String    @map("user_a_id") @db.Char(36)
  userBId    String    @map("user_b_id") @db.Char(36)
  deletedAt  DateTime? @map("deleted_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  dealId     String?   @map("deal_id") @db.Char(36)
  productId  String?   @map("product_id") @db.Char(36)
  contactId  String?   @map("contact_id") @db.Char(36)
  assignedTo String?   @map("assigned_to") @db.Char(36)

  tenant   Tenant                @relation(fields: [tenantId], references: [id])
  userA    User                  @relation("ConversationUserA", fields: [userAId], references: [id])
  userB    User                  @relation("ConversationUserB", fields: [userBId], references: [id])
  deal     Deal?                 @relation(fields: [dealId], references: [id])
  product  Product?              @relation("ConversationProduct", fields: [productId], references: [id])
  contact  Contact?              @relation("ConversationContact", fields: [contactId], references: [id])
  assignee User?                 @relation("ConversationAssignee", fields: [assignedTo], references: [id])
  messages ConversationMessage[]

  @@index([tenantId, userAId, userBId], map: "idx_conversations_tenant_users")
  @@map("conversations")
}

model ConversationMessage {
  id             String    @id @db.Char(36)
  tenantId       String    @map("tenant_id") @db.Char(36)
  conversationId String    @map("conversation_id") @db.Char(36)
  senderId       String    @map("sender_id") @db.Char(36)
  body           String    @db.Text
  createdAt      DateTime  @default(now()) @map("created_at")
  deletedAt      DateTime? @map("deleted_at")

  tenant       Tenant       @relation(fields: [tenantId], references: [id])
  conversation Conversation @relation(fields: [conversationId], references: [id])
  sender       User         @relation(fields: [senderId], references: [id])

  @@index([tenantId, conversationId, createdAt], map: "idx_conversation_messages")
  @@map("conversation_messages")
}

model DealComment {
  id        String    @id @db.Char(36)
  tenantId  String    @map("tenant_id") @db.Char(36)
  dealId    String    @map("deal_id") @db.Char(36)
  authorId  String    @map("author_id") @db.Char(36)
  body      String    @db.Text
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])
  deal   Deal   @relation(fields: [dealId], references: [id])
  author User   @relation(fields: [authorId], references: [id])

  @@index([tenantId, dealId], map: "idx_deal_comments_tenant_deal")
  @@map("deal_comments")
}

model CsvImportJob {
  id           String             @id @db.Char(36)
  tenantId     String             @map("tenant_id") @db.Char(36)
  createdBy    String             @map("created_by") @db.Char(36)
  filePath     String             @map("file_path") @db.VarChar(255)
  status       CsvImportJobStatus @default(queued)
  totalRows    Int                @default(0) @map("total_rows")
  insertedRows Int                @default(0) @map("inserted_rows")
  failedRows   Int                @default(0) @map("failed_rows")
  errorMessage String?            @map("error_message") @db.Text
  reportPath   String?            @map("report_path") @db.VarChar(255)
  createdAt    DateTime           @default(now()) @map("created_at")
  updatedAt    DateTime           @updatedAt @map("updated_at")
  tenant       Tenant             @relation(fields: [tenantId], references: [id])
  creator      User               @relation("CsvImportCreator", fields: [createdBy], references: [id])

  @@index([tenantId, status], map: "idx_csv_import_jobs_tenant_status")
  @@map("csv_import_jobs")
}

model Product {
  id          String      @id @db.Char(36)
  tenantId    String      @map("tenant_id") @db.Char(36)
  companyId   String      @map("company_id") @db.Char(36)
  name        String      @db.VarChar(180)
  description String?     @db.Text
  price       Decimal     @db.Decimal(10, 2)
  category    String?     @db.VarChar(120)
  imageUrl    String?     @db.VarChar(255)
  quantity    Int         @default(10)
  inStock     Boolean     @default(true) @map("in_stock")
  createdBy   String      @map("created_by") @db.Char(36)
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")
  deletedAt   DateTime?   @map("deleted_at")
  tenant      Tenant      @relation(fields: [tenantId], references: [id])
  company     Company     @relation(fields: [companyId], references: [id])
  creator     User        @relation("ProductCreator", fields: [createdBy], references: [id])
  orderItems    OrderItem[]
  deals         Deal[]
  conversations Conversation[] @relation("ConversationProduct")

  @@index([tenantId, companyId], map: "idx_products_tenant_company")
  @@map("products")
}

model Order {
  id              String      @id @db.Char(36)
  tenantId        String      @map("tenant_id") @db.Char(36)
  buyerId         String      @map("buyer_id") @db.Char(36)
  totalAmount     Decimal     @map("total_amount") @db.Decimal(12, 2)
  status          OrderStatus @default(pending)
  shippingAddress Json?       @map("shipping_address")
  notes           String?     @db.Text
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")
  dealId          String?     @unique @map("deal_id") @db.Char(36)
  tenant          Tenant      @relation(fields: [tenantId], references: [id])
  buyer           User        @relation(fields: [buyerId], references: [id])
  deal            Deal?       @relation(fields: [dealId], references: [id])
  orderItems      OrderItem[]

  @@index([tenantId, buyerId, status], map: "idx_orders_tenant_buyer_status")
  @@map("orders")
}

model OrderItem {
  id        String  @id @db.Char(36)
  orderId   String  @map("order_id") @db.Char(36)
  productId String  @map("product_id") @db.Char(36)
  quantity  Int
  unitPrice Decimal @map("unit_price") @db.Decimal(10, 2)
  order     Order   @relation(fields: [orderId], references: [id])
  product   Product @relation(fields: [productId], references: [id])

  @@index([orderId, productId], map: "idx_order_items_order_product")
  @@map("order_items")
}

enum Role {
  owner
  admin
  sales
  staff
  user
}

enum ContactStatus {
  lead
  active
  inactive
}

enum DealStage {
  prospect
  discovery
  qualified
  proposal
  negotiation
  won
  lost
}

enum ActivityType {
  call
  email
  meeting
}

enum ReminderEntity {
  contact
  deal
}

enum ReminderStatus {
  pending
  sent
  failed
}

enum CsvImportJobStatus {
  queued
  processing
  completed
  failed
}

enum OrderStatus {
  pending
  confirmed
  shipped
  delivered
  cancelled
}
